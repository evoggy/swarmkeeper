import { Button, Palette, ScrollView, VerticalBox, HorizontalBox, LineEdit, CheckBox, ComboBox } from "std-widgets.slint";
import { UnitData, UnitState, JournalEntryData } from "unit-card.slint";

component HeaderCell inherits Rectangle {
    in property <string> label;
    in property <int> column-index;
    in property <int> active-col;
    in property <bool> active-ascending;
    in-out property <length> col-width;
    in property <length> min-col-width: 40px;
    callback clicked();

    border-width: 1px;
    border-color: Palette.border;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 8px;

        Text {
            text: active-col == column-index ? (active-ascending ? label + " ▲" : label + " ▼") : label;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    // Main click area for sorting (excludes resize handle)
    TouchArea {
        x: 0px;
        y: 0px;
        width: root.width - 5px;
        height: root.height;
        clicked => { root.clicked(); }
        mouse-cursor: pointer;
    }

    // Resize handle on right edge
    Rectangle {
        x: root.width - 5px;
        y: 0px;
        width: 5px;
        height: root.height;
        background: resize-ta.has-hover || resize-ta.pressed ? Palette.accent-background : transparent;

        resize-ta := TouchArea {
            mouse-cursor: col-resize;
            moved => {
                root.col-width = max(root.min-col-width, root.col-width + (self.mouse-x - self.pressed-x));
            }
        }
    }
}

component BatteryCell inherits Rectangle {
    in property <float> voltage;

    property <float> level: clamp((voltage - 3.0) / 1.2, 0.0, 1.0);
    property <color> bar-color: level < 0.2 ? red
                               : level < 0.5 ? orange
                               : limegreen;

    VerticalLayout {
        padding-top: 2px;
        padding-bottom: 2px;
        padding-left: 6px;
        padding-right: 6px;
        spacing: 1px;
        alignment: center;

        Rectangle {
            height: 10px;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.foreground.transparentize(0.5);

            Rectangle {
                x: 2px;
                y: 2px;
                width: max(0px, (parent.width - 4px) * level);
                height: parent.height - 4px;
                border-radius: 1px;
                background: bar-color;
            }
        }

        Text {
            text: voltage > 0 ? "\{round(voltage * 100) / 100}V" : "";
            font-size: 9px;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}

component LinkQualityCell inherits Rectangle {
    in property <float> quality;

    property <color> bar-color: quality < 0.5 ? red
                               : quality < 0.8 ? orange
                               : limegreen;

    VerticalLayout {
        padding-top: 2px;
        padding-bottom: 2px;
        padding-left: 6px;
        padding-right: 6px;
        spacing: 1px;
        alignment: center;

        Rectangle {
            height: 10px;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.foreground.transparentize(0.5);

            Rectangle {
                x: 2px;
                y: 2px;
                width: max(0px, (parent.width - 4px) * quality);
                height: parent.height - 4px;
                border-radius: 1px;
                background: bar-color;
            }
        }

        Text {
            text: quality > 0 ? "\{round(quality * 100)}%" : "";
            font-size: 9px;
            horizontal-alignment: center;
            overflow: elide;
        }
    }
}

component Cell inherits Rectangle {
    in property <string> value;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 2px;

        Text {
            text: value;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component DetailRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;

    spacing: 8px;
    padding-left: 16px;
    padding-right: 16px;

    Text {
        text: label;
        font-size: 12px;
        font-weight: 600;
        color: Palette.foreground.transparentize(0.3);
        width: 90px;
    }

    Text {
        text: value;
        font-size: 12px;
        horizontal-stretch: 1;
        overflow: elide;
    }
}

component StickIndicator inherits VerticalLayout {
    in property <string> label-x;
    in property <string> label-y;
    in property <float> value-x;  // -1 to 1
    in property <float> value-y;  // -1 to 1

    spacing: 2px;
    alignment: center;

    Rectangle {
        width: 100px;
        height: 100px;
        border-width: 1px;
        border-color: Palette.border;
        border-radius: 4px;
        background: Palette.background.darker(0.03);

        // Horizontal crosshair
        Rectangle {
            x: 0px;
            y: (parent.height - 1px) / 2;
            width: parent.width;
            height: 1px;
            background: Palette.border.transparentize(0.3);
        }

        // Vertical crosshair
        Rectangle {
            x: (parent.width - 1px) / 2;
            y: 0px;
            width: 1px;
            height: parent.height;
            background: Palette.border.transparentize(0.3);
        }

        // Dot indicator
        Rectangle {
            width: 12px;
            height: 12px;
            border-radius: 6px;
            background: dodgerblue;
            x: (parent.width - self.width) / 2 + value-x * (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2 - value-y * (parent.height - self.height) / 2;
        }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 4px;
        Text {
            text: "← " + label-x + " →";
            font-size: 9px;
            color: Palette.foreground.transparentize(0.4);
            horizontal-alignment: center;
        }
    }

    HorizontalLayout {
        alignment: center;
        Text {
            text: "↕ " + label-y;
            font-size: 9px;
            color: Palette.foreground.transparentize(0.4);
            horizontal-alignment: center;
        }
    }
}

component BatteryBar inherits Rectangle {
    in property <float> voltage;

    property <float> level: clamp((voltage - 3.0) / 1.2, 0.0, 1.0);
    property <color> bar-color: level < 0.2 ? red
                               : level < 0.5 ? orange
                               : limegreen;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 8px;

        Text {
            text: "Battery";
            font-size: 12px;
            font-weight: 600;
            color: Palette.foreground.transparentize(0.3);
            width: 90px;
            vertical-alignment: center;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: 16px;
            border-radius: 3px;
            border-width: 1px;
            border-color: Palette.foreground.transparentize(0.5);

            Rectangle {
                x: 2px;
                y: 2px;
                width: max(0px, (parent.width - 4px) * level);
                height: parent.height - 4px;
                border-radius: 2px;
                background: bar-color;
            }
        }

        Text {
            text: voltage > 0 ? "\{round(voltage * 100) / 100}V" : "N/A";
            font-size: 12px;
            width: 50px;
            vertical-alignment: center;
        }
    }
}

